# Server
# Use 4001 by default so it does not collide with other local APIs on 4000
PORT=4001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
# Comma-separated extra allowed origins (Next may fall back to 3001)
CLIENT_URLS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:8501
TRUST_PROXY=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumeai?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional service API key (required for Streamlit → API in production if set)
API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# Free by default: Groq (OpenAI-compatible). Paid OpenAI optional.
# Groq free key: https://console.groq.com/keys
LLM_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# To use paid OpenAI instead:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=resumeai-dev

# Observability
LOG_LEVEL=info
SENTRY_DSN=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AI_RATE_LIMIT_MAX=30
