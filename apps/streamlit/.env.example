# Streamlit backend — local defaults (copy to .env and adjust)
APP_ENV=development

# Local API (matches apps/api PORT; Docker Compose overrides to http://api:4000/api/v1)
API_BASE_URL=http://localhost:4002/api/v1
API_KEY=

# Database — local Postgres (Docker Compose overrides to @postgres host)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumeai

# OpenAI / Groq (optional for pages that call LLM directly)
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile

# AWS S3 — leave empty locally unless using MinIO/AWS
# docker compose --profile local-s3 up minio
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=

# Error tracking
SENTRY_DSN=
