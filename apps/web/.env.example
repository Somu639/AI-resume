# Browser on Vercel: point at the public API
NEXT_PUBLIC_API_URL=https://ai-resume-api-tau.vercel.app/api/v1

# Local only — proxy /api/v1 → Express (ignored when NEXT_PUBLIC_API_URL is absolute)
API_PROXY_TARGET=http://localhost:4002

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Server-only (Vercel)
SENTRY_AUTH_TOKEN=
